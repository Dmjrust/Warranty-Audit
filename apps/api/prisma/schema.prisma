generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector")]
}

// ─── Auth ─────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String    @default("")
  password      String    @default("")
  role          String    @default("tecnico")
  status        String    @default("PENDING")
  tenantId      String?
  tenant        Tenant?   @relation(fields: [tenantId], references: [id])
  inviteToken   String?   @unique
  inviteExpiry  DateTime?
  lastLogin     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("users")
}

// ─── Multi-tenancy ────────────────────────────────────────────────────────────

model Tenant {
  id                     String            @id @default(uuid())
  name                   String
  cnpj                   String?           @unique
  manufacturerId         String?
  manufacturer           Manufacturer?     @relation(fields: [manufacturerId], references: [id])
  activePolicyVersionId  String?
  status                 String            @default("ACTIVE")
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt
  users                  User[]
  processes              ProcessInstance[]

  @@map("tenants")
}

model Manufacturer {
  id        String           @id @default(uuid())
  code      String           @unique
  name      String
  status    String           @default("ACTIVE")
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  templates PolicyTemplate[]
  tenants   Tenant[]
  ragDocs   RagDocument[]

  @@map("manufacturers")
}

// ─── Policy Engine ────────────────────────────────────────────────────────────

model PolicyTemplate {
  id             String          @id @default(uuid())
  manufacturerId String
  manufacturer   Manufacturer    @relation(fields: [manufacturerId], references: [id])
  code           String          @unique
  name           String
  description    String?
  status         String          @default("ACTIVE")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  versions       PolicyVersion[]

  @@map("policy_templates")
}

model PolicyVersion {
  id               String            @id @default(uuid())
  policyTemplateId String
  template         PolicyTemplate    @relation(fields: [policyTemplateId], references: [id])
  versionCode      String
  status           String            @default("DRAFT")
  effectiveFrom    DateTime?
  effectiveTo      DateTime?
  schemaJson       String
  publishedAt      DateTime?
  publishedBy      String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  processes        ProcessInstance[]

  @@map("policy_versions")
}

// ─── Warranty Process ─────────────────────────────────────────────────────────

model ProcessInstance {
  id                 String        @id @default(uuid())
  tenantId           String
  tenant             Tenant        @relation(fields: [tenantId], references: [id])
  policyVersionId    String
  policyVersion      PolicyVersion @relation(fields: [policyVersionId], references: [id])
  status             String        @default("DRAFT")
  currentStep        String        @default("VEHICLE")
  vehicleDataJson    String?
  checklistDataJson  String?
  analysisDataJson   String?
  scoringResultJson  String?
  decisionResultJson String?
  slaStatus          String        @default("green")
  slaDeadline        DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  scores             Score[]

  @@map("process_instances")
}

// ─── Scoring ──────────────────────────────────────────────────────────────────

model Score {
  id              String          @id @default(uuid())
  processId       String
  process         ProcessInstance @relation(fields: [processId], references: [id])
  policyVersionId String
  scoreSd         Float?
  scoreSt         Float?
  scoreSh         Float?
  scoreFinal      Float?
  decision        String?
  rulesApplied    String?
  ragChunksUsed   String?
  calculatedAt    DateTime        @default(now())

  @@map("scores")
}

// ─── RAG Knowledge Base ───────────────────────────────────────────────────────

model RagDocument {
  id             String       @id @default(uuid())
  manufacturerId String
  manufacturer   Manufacturer @relation(fields: [manufacturerId], references: [id])
  tenantId       String?
  fonte          String
  sistema        String
  modeloVeiculo  String?
  titulo         String
  conteudo       String
  metadados      String?
  criadoEm       DateTime     @default(now())
  vigenteAte     DateTime?

  @@map("rag_documents")
}
