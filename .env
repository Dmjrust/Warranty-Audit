POSTGRES_USER="warranty"
POSTGRES_PASSWORD="warranty_dev_pass"
POSTGRES_DB="warranty_audit"

# ── Redis (BullMQ) ─────────────────────────────────────────────────────────────
REDIS_PASSWORD="redis_dev_pass_change_me"
