# ── API ────────────────────────────────────────────────────────────────────────
API_URL="http://api:4000"
API_PORT="4000"
NEXT_PUBLIC_API_URL="http://localhost:4000"

# ── OpenAI (optional for MVP local testing) ────────────────────────────────────
OPENAI_API_KEY=""

