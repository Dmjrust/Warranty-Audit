# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://warranty:warranty_dev_pass@localhost:5432/warranty_audit"

# Needed by docker-compose.prod.yml (replaced by DATABASE_URL in Railway/Render)
POSTGRES_USER="warranty"
POSTGRES_PASSWORD="warranty_dev_pass"
POSTGRES_DB="warranty_audit"

# ── Redis (BullMQ) ─────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_PASSWORD=""

# ── Auth ───────────────────────────────────────────────────────────────────────
JWT_SECRET="change-me-in-production-use-long-random-string"
JWT_EXPIRES_IN="7d"
NEXTAUTH_SECRET="change-me-in-production-use-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# ── API ────────────────────────────────────────────────────────────────────────
API_URL="http://localhost:4000"
API_PORT=4000
NEXT_PUBLIC_API_URL="http://localhost:4000"

# ── OpenAI ─────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=""

# ── Cloudflare R2 ──────────────────────────────────────────────────────────────
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="warranty-evidence"
R2_PUBLIC_URL=""
