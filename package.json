{
  "name": "warranty-audit",
  "private": true,
  "workspaces": ["apps/*"],
  "scripts": {
    "dev:api": "npm -w apps/api run dev",
    "dev:web": "npm -w apps/web run dev",
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "build": "npm -w apps/api run build && npm -w apps/web run build",
    "db:generate": "npm -w apps/api run db:generate",
    "db:migrate": "npm -w apps/api run db:migrate",
    "db:seed": "npm -w apps/api run db:seed",
    "db:studio": "npm -w apps/api run db:studio"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "typescript": "~5.8.2"
  }
}
